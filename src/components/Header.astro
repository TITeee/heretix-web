---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
const otherLang = lang === 'en' ? 'ja' : 'en';
const otherLangLabel = lang === 'en' ? '日本語' : 'English';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-gray-950/80 backdrop-blur border-b border-gray-800">
  <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href={`${base}${lang}/`} class="font-bold text-lg text-white tracking-tight">
      heretix
    </a>
    <nav class="flex items-center gap-6 text-sm">
      <a
        href={`${base}${otherLang}/`}
        class="text-gray-400 hover:text-white transition-colors"
      >
        {otherLangLabel}
      </a>
      <a
        href="https://github.com/TITeee"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 hover:text-white transition-colors"
      >
        {t.navGitHub}
      </a>
    </nav>
  </div>
</header>
