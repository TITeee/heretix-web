---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const components = [
  {
    name: t.cliName,
    description: t.cliDescription,
    github: 'https://github.com/TITeee/heretix-cli',
    tech: ['Go'],
    color: 'green',
  },
  {
    name: t.apiName,
    description: t.apiDescription,
    github: 'https://github.com/TITeee/heretix-api',
    tech: ['Node.js', 'Fastify', 'Prisma', 'PostgreSQL', 'TypeScript'],
    color: 'blue',
  },
  {
    name: t.managementName,
    description: t.managementDescription,
    github: 'https://github.com/TITeee/heretix-management',
    tech: ['Next.js', 'Tailwind CSS', 'Prisma', 'PostgreSQL', 'Auth.js'],
    color: 'purple',
  },
];

const colorMap = {
  green: {
    border: 'border-green-700/40',
    bg: 'bg-green-900/10',
    title: 'text-green-400',
    tag: 'bg-green-900/30 text-green-300 border-green-700/40',
  },
  blue: {
    border: 'border-blue-700/40',
    bg: 'bg-blue-900/10',
    title: 'text-blue-400',
    tag: 'bg-blue-900/30 text-blue-300 border-blue-700/40',
  },
  purple: {
    border: 'border-purple-700/40',
    bg: 'bg-purple-900/10',
    title: 'text-purple-400',
    tag: 'bg-purple-900/30 text-purple-300 border-purple-700/40',
  },
};
---

<section class="py-24 px-4 bg-gray-900/50">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-6xl font-bold text-white text-center mb-16">{t.componentsTitle}</h2>
    <div class="grid md:grid-cols-3 gap-6">
      {components.map((comp) => {
        const colors = colorMap[comp.color as keyof typeof colorMap];
        return (
          <div class={`rounded-xl border ${colors.border} ${colors.bg} p-6 flex flex-col`}>
            <h3 class={`font-bold text-lg mb-3 font-mono ${colors.title}`}>{comp.name}</h3>
            <p class="text-gray-400 text-sm leading-relaxed flex-1 mb-4">{comp.description}</p>
            <div class="flex flex-wrap gap-2 mb-4">
              {comp.tech.map((tag) => (
                <span class={`px-2 py-0.5 rounded text-xs border ${colors.tag}`}>{tag}</span>
              ))}
            </div>
            <a
              href={comp.github}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors mt-auto"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              GitHub
            </a>
          </div>
        );
      })}
    </div>
  </div>
</section>
