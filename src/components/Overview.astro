---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-24 px-4 bg-gray-900/50">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-6xl font-bold text-white mb-6">{t.overviewTitle}</h2>
    <p class="text-white text-lg leading-relaxed">{t.overviewBody}</p>
  </div>
</section>
