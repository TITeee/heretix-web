---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-24 px-4">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-6xl font-bold text-white text-center mb-16">{t.architectureTitle}</h2>
    <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-0">

      <!-- Sources -->
      <div class="flex flex-col gap-2 text-center">
        <div class="text-base text-white mb-2 uppercase tracking-wide">Vulnerability Sources</div>
        {['NVD', 'OSV', 'CISA KEV', 'EPSS', 'Vendor Advisory'].map((src) => (
          <div class="px-3 py-1 rounded bg-gray-800 border border-gray-700 text-gray-400 text-xl">
            {src}
          </div>
        ))}
      </div>

      <!-- Arrow -->
      <div class="hidden md:flex items-center px-4 text-white">
        <svg class="w-8 h-4" viewBox="0 0 32 16" fill="none">
          <path d="M0 8h28M22 2l8 6-8 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="flex md:hidden text-white rotate-90">
        <svg class="w-8 h-4" viewBox="0 0 32 16" fill="none">
          <path d="M0 8h28M22 2l8 6-8 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- API -->
      <div class="rounded-xl border-4 border-blue-700/50 bg-blue-900/20 px-6 py-4 text-center min-w-32">
        <div class="text-blue-400 font-bold text-xl">heretix-api</div>
        <div class="text-white text-base mt-1">Aggregation &amp; Search</div>
      </div>

      <!-- Arrow -->
      <div class="hidden md:flex items-center px-4 text-white">
        <svg class="w-8 h-4" viewBox="0 0 32 16" fill="none">
          <path d="M0 8h28M22 2l8 6-8 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="flex md:hidden text-white rotate-90">
        <svg class="w-8 h-4" viewBox="0 0 32 16" fill="none">
          <path d="M0 8h28M22 2l8 6-8 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- Management -->
      <div class="rounded-xl border-4 border-purple-700/50 bg-purple-900/20 px-6 py-4 text-center min-w-36">
        <div class="text-purple-400 font-bold text-xl">heretix-management</div>
        <div class="text-white text-base mt-1">Web Console</div>
      </div>

      <!-- Double arrow (CLI feeds management) -->
      <div class="hidden md:flex items-center px-4 text-white">
        <svg class="w-8 h-4" viewBox="0 0 32 16" fill="none">
          <path d="M32 8H4M10 2L2 8l8 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="flex md:hidden text-white rotate-90">
        <svg class="w-8 h-4" viewBox="0 0 32 16" fill="none">
          <path d="M32 8H4M10 2L2 8l8 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- CLI + Targets -->
      <div class="flex flex-col gap-2 text-center">
        <div class="rounded-xl border-4 border-green-700/50 bg-green-900/20 px-6 py-4 text-center">
          <div class="text-green-400 font-bold text-xl whitespace-nowrap">heretix-cli</div>
          <div class="text-white text-base mt-1">Package Scanner</div>
        </div>
        <div class="text-base text-white mt-2 uppercase tracking-wide">Targets</div>
        {['Linux Host', 'Docker Image'].map((t) => (
          <div class="px-3 py-1 rounded bg-gray-800 border border-gray-700 text-gray-400 text-xl whitespace-nowrap">
            {t}
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
