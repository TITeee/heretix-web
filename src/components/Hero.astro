---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
---

<section class="min-h-screen flex flex-col px-4 pt-14 pb-12">
  <div class="flex-1 flex items-center justify-center">
  <div class="relative max-w-5xl mx-auto text-center">
    <!-- Background image (behind text) -->
    <div class="absolute inset-0 -mx-8 flex items-center justify-center">
      <img
        src={`${base}/dashboard-overview.png`}
        alt="heretix console screenshot"
        class="rounded-xl border border-gray-700 shadow-2xl w-full max-w-3xl mx-auto opacity-20 blur-none"
      />
    </div>
    <!-- Text content (on top) -->
    <div class="relative z-10">
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-white leading-tight mb-6">
        {t.heroTagline}
      </h1>
      <p class="text-lg sm:text-xl text-white mb-10 leading-relaxed max-w-2xl mx-auto">
        {t.heroDescription}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#quickstart"
          class="px-6 py-3 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-semibold transition-colors"
        >
          {t.heroCTAPrimary}
        </a>
        <a
          href="https://github.com/TITeee"
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-3 rounded-lg border border-gray-700 hover:border-white text-gray-300 hover:text-white font-semibold transition-colors"
        >
          {t.heroCTASecondary}
        </a>
      </div>

    </div>
  </div>
  </div>

  <!-- Thumbnails (bottom of section) -->
  <div class="flex gap-4 justify-center w-full max-w-3xl mx-auto">
    {[
      { src: 'dashboard-overview.png', label: 'Dashboard Overview' },
      { src: 'dashboard-tags.png',    label: 'Dashboard Tags' },
      { src: 'assets.png', label: 'Assets' },
      { src: 'alerts.png', label: 'Alerts' },
      { src: 'alerts-details.png', label: 'Alerts Details'},
    ].map(({ src, label }) => (
      <button
        class="lightbox-trigger w-1/3 rounded-lg overflow-hidden border border-gray-700 hover:border-gray-400 transition-colors cursor-pointer"
        data-src={`${base}/${src}`}
        aria-label={label}
      >
        <img
          src={`${base}/${src}`}
          alt={label}
          class="w-full h-auto block"
        />
      </button>
    ))}
  </div>
</section>

<!-- Lightbox dialog -->
<dialog
  id="lightbox"
  class="bg-transparent backdrop:bg-black/80 p-0 max-w-5xl w-full mx-auto my-auto"
>
  <img id="lightbox-img" src="" alt="" class="w-full h-auto rounded-xl" />
</dialog>

<script>
  const dialog = document.getElementById('lightbox') as HTMLDialogElement;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

  document.querySelectorAll<HTMLButtonElement>('.lightbox-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      lightboxImg.src = btn.dataset.src ?? '';
      lightboxImg.alt = btn.getAttribute('aria-label') ?? '';
      dialog.showModal();
    });
  });

  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });
</script>
